# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For local development, get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# For local development, use http://localhost:3000
APP_URL="http://localhost:3000"

# Supabase Configuration
# Required if using Supabase features. Create a project at https://supabase.com
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# API_KEY: Required for Veo video generation models.
# Users select this via the platform's key selection dialog.
# For local development, set this if using paid features.
API_KEY=
